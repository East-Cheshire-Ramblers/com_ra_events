<?xml version="1.0" encoding="utf-8"?>
<form>
    <fields name="filter">
        <field name="search" type="text" hint="COM_RA_EVENTS_SEARCH_FILTER_SUBMIT"
               label="COM_USERS_FILTER_SEARCH_DESC"
               class="js-stools-search-string" />

        <field name="num_places" label="Number" type="list" onchange="this.form.submit();" default="Number od places">
  <option value="">Number of places</option>
  <option value="1">One place</option>
  <option value="2">Two places</option>
</field>


    </fields>
    <fields name="list">

        <field name="fullordering"
               type="list"
               label="COM_RA_EVENTS_LIST_FULL_ORDERING"
               description="COM_RA_EVENTS_LIST_FULL_ORDERING_DESC"
               onchange="this.form.submit();"
               default="a.id DESC"
        >
            <option value="">JGLOBAL_SORT_BY</option>
            <option value="a.id ASC">COM_RA_EVENTS_ID_ASC</option><option value="a.id DESC">COM_RA_EVENTS_ID_DESC</option><option value="a.state ASC">COM_RA_EVENTS_STATE_ASC</option><option value="a.state DESC">COM_RA_EVENTS_STATE_DESC</option><option value="a.title ASC">COM_RA_EVENTS_TITLE_ASC</option><option value="a.title DESC">COM_RA_EVENTS_TITLE_DESC</option><option value="a.partner ASC">COM_RA_EVENTS_PARTNER_ASC</option><option value="a.partner DESC">COM_RA_EVENTS_PARTNER_DESC</option><option value="a.user_id ASC">COM_RA_EVENTS_USER_ID_ASC</option><option value="a.user_id DESC">COM_RA_EVENTS_USER_ID_DESC</option><option value="a.event_id ASC">COM_RA_EVENTS_EVENT_ID_ASC</option><option value="a.event_id DESC">COM_RA_EVENTS_EVENT_ID_DESC</option><option value="a.num_persons ASC">COM_RA_EVENTS_NUM_PERSONS_ASC</option><option value="a.num_persons DESC">COM_RA_EVENTS_NUM_PERSONS_DESC</option>

        </field>

       <field name="limit"
               type="limitbox"
               label="COM_RA_EVENTS_LIST_LIMIT"
               description="COM_RA_EVENTS_LIST_LIMIT_DESC"
               class="input-mini"
               default="25"
               onchange="this.form.submit();"
        />

    </fields>
</form>