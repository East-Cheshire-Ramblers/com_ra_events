<?xml version="1.0" encoding="utf-8"?>
<config>
    <fieldset label="Ramblers Events" name="ra_events">
	<field
            name="events_max_chars"
            type="text"
            filter="integer"
            label="Max chars to display"
            description="Maximum number of characters from Details to display"
            default="1500"
    />  
        <field
            name="show_group"
            type="radio"
            default="1"
            label="Include Group code"
            description="Require specification of the Group for each Event"
            layout="joomla.form.field.radio.switcher"
            >
            <option value="0">JNO</option>
            <option value="1">JYES</option>
        </field>      
        <field
            name="default_group"
            type="text"
            showon="show_group:1"
            filter="alnum"
            label="Default Group code"
            description="Default Group for each Event"
        /> 
        <field name="website_base"
                type="text"
                label="Website address" 
                description="Used when creating links in emails" 
                required="true"
                hint="https://xxxramblers.org.uk"/>

    </fieldset>
    <fieldset label="Emails" name="emails">
        <field name="email_header" 
               editor="|" 
               buttons="true" 
               filter="raw"
               type="editor" 
               default="Sent from the Group website by the software package RA Events" 
               label="Email Header" 
               description="Text at the top of all messages from this component"/>        
        <field name="header_height"
               maxlength="3" 
               filter="safehtml" 
               type="text" 
               label="Header height" 
               description="Height of the overall header, in pixels" 
               default="150"/>     
        <field
            name="colour_header" 
            type="color" 
            format="rgba"
            label="Header colour"
            default="rgba(246, 177, 157, 0.5)"
            description="Background colour of the email header"
        /> 
        <field name="image_height"
               maxlength="3" 
               filter="safehtml" 
               type="text" 
               label="Image height" 
               description="Height of the header image, in pixels" 
               default="90"/>   
        <field name="image_width"
               maxlength="3" 
               filter="safehtml" 
               type="text" 
               label="Image width" 
               description="Width of the header image, in pixels" 
               default="90"/>      
    </fieldset>
    <fieldset label="Bookings" name="bookings">
	<field
            name="max_bookings"
            type="text"
            filter="integer"
            label="Default maximum"
            description="Default for Maximum number of bookings"
            default="20"
        />          
        <field
            name="default_contact"
            type="sql"
            label="Default contact"
            description="Person to be contacted about Events if no contact available"
            sql_select="id, name" 
            sql_from="`#__contact_details` WHERE published=1" 
            key_field="id" 
            value_field="name"
            required="true"
        />         
        <field name="default_message" 
               editor="|" 
               buttons="true" 
               filter="raw"
               type="editor" 
               default="A Shared Event has been copied into the database, but the contact was blank of missing. You have temporarily been designated as the point of contact.
Please arrange for an appropriate Contact to be created on your site. Once this is done, the Event will automatically be updated to remove your name." 
               label="Default Message" 
               description="Text to be emailed to the default contact"/> 
        <field
            name="booking_list_public"
            type="radio"
            default="1"
            label="Make booking list public"
            description="Specify whether booking list is available to all logged in users"
            layout="joomla.form.field.radio.switcher"
            >
            <option value="1">JYES</option>
        </field>
        <field name="booking_receipt"
               editor="|" 
               buttons="true" 
               filter="ComponentHelper::filterText" 
               type="editor" 
               default="Thank you" 
               label="Booking receipt" 
               description="Message to be sent when booking has been received"/>
    </fieldset>
    <fieldset name="component">
        <field
            name="save_history"
            type="radio"
            default="0"
            label="JGLOBAL_SAVE_HISTORY_OPTIONS_LABEL"
            description="JGLOBAL_SAVE_HISTORY_OPTIONS_DESC"
            layout="joomla.form.field.radio.switcher"
            >
            <option value="0">JNO</option>
            <option value="1">JYES</option>
        </field>

        <field name="history_limit" type="text" filter="integer" label="JGLOBAL_HISTORY_LIMIT_OPTIONS_LABEL" description="JGLOBAL_HISTORY_LIMIT_OPTIONS_DESC" default="5"/>

     
        <field
          name="sef_ids"
          type="radio"
          layout="joomla.form.field.radio.switcher"
          default="0"
          label="JGLOBAL_SEF_NOIDS_LABEL"
          description="JGLOBAL_SEF_NOIDS_DESC"
          filter="integer"
          >
          <option value="0">JNO</option>
          <option value="1">JYES</option>
        </field>
    </fieldset>
    <fieldset name="permissions" description="JCONFIG_PERMISSIONS_DESC" label="JCONFIG_PERMISSIONS_LABEL">
        <field name="rules" 
               type="rules" 
               component="com_ra_events" 
               class="inputbox" 
               filter="rules" 
               validate="rules" 
               label="JCONFIG_PERMISSIONS_LABEL" 
               section="component" />
    </fieldset>    
</config>
