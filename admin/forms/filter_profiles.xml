<?xml version="1.0" encoding="utf-8"?>
<form>
    <fields name="filter">
        <field name="search" type="text" description="Submit"
               label="COM_USERS_FILTER_SEARCH_DESC"
               class="js-stools-search-string" />
       
    </fields>

    <fields name="list">

        <field name="fullordering"
               type="list"
               label="COM_RA_EVENTS_LIST_FULL_ORDERING"
               description="COM_RA_EVENTS_LIST_FULL_ORDERING_DESC"
               onchange="this.form.submit();"
               default="a.id DESC"
        >
            <option value="">JGLOBAL_SORT_BY</option>
            <option value="a.id ASC">ID Acending</option>
            <option value="a.id DESC">ID Decending</option>
            <option value="a.home_group ASC">Group Acending</option>
            <option value="a.home_group DESC">Group Decending</option>
            <option value="a.preferred_name ASC">Preferred name Acending</option>
            <option value="a.preferred_name DESC">Preferred name Decending</option>
            <option value="a.real_name ASC">Group Acending</option>
            <option value="a.real_name DESC">Name Decending</option>
            <option value="a.email ASC">Email Acending</option>
            <option value="a.email DESC">Email Decending</option>



        </field>

       <field name="limit"
               type="limitbox"
               label="COM_RA_EVENTS_LIST_LIMIT"
               description="COM_RA_EVENTS_LIST_LIMIT_DESC"
               class="input-mini"
               default="25"
               onchange="this.form.submit();"
        />

    </fields>

</form>